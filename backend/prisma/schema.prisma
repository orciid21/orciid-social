generator client {
  provider = "prisma-client-js"
  // Use the BINARY query engine (separate subprocess) instead of the default
  // "library" (Node-API) engine. The library engine runs inside the Node
  // process and, under Hostinger's shared-host resource pressure, repeatedly
  // panicked with "PANIC: timer has gone away" (a libuv/Tokio timer starvation
  // bug) on the first query of fresh boots — wedging every DB route at 500 with
  // no in-process recovery. The binary engine isolates the query engine in its
  // own process with its own runtime, which is immune to that timer panic.
  engineType = "binary"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  name          String
  email         String    @unique
  password      String
  avatar        String?
  role          Role      @default(USER)
  isVerified    Boolean   @default(false)
  verifyToken   String?
  resetToken    String?
  resetTokenExp DateTime?
  fbConnectToken String?  @db.Text
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  subscription    Subscription?
  socialAccounts  SocialAccount[]
  posts           Post[]
  workspaces      WorkspaceMember[]
}

model Subscription {
  id                   String             @id @default(uuid())
  userId               String             @unique
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique
  plan                 Plan               @default(FREE)
  status               SubscriptionStatus @default(TRIALING)
  trialEndsAt          DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
}

model Workspace {
  id        String            @id @default(uuid())
  name      String
  slug      String            @unique
  logo      String?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  members     WorkspaceMember[]
  accounts    SocialAccount[]
  posts       Post[]
  invitations Invitation[]
}

// Pending team invitations. When the invited email belongs to an existing user
// we add them straight to WorkspaceMember; otherwise we keep a PENDING row here
// and convert it to a membership when that email registers (see auth register).
model Invitation {
  id          String    @id @default(uuid())
  workspaceId String
  email       String
  role        WsRole    @default(MEMBER)
  token       String    @unique @default(uuid())
  status      String    @default("PENDING")
  invitedBy   String?
  createdAt   DateTime  @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, email])
}

model WorkspaceMember {
  id          String    @id @default(uuid())
  userId      String
  workspaceId String
  role        WsRole    @default(MEMBER)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@unique([userId, workspaceId])
}

model SocialAccount {
  id           String         @id @default(uuid())
  userId       String
  workspaceId  String?
  platform     Platform
  platformId   String
  name         String
  username     String?
  avatar       String?
  accessToken  String         @db.Text
  refreshToken String?        @db.Text
  tokenExpiry  DateTime?
  isActive     Boolean        @default(true)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace? @relation(fields: [workspaceId], references: [id])
  posts     PostAccount[]

  @@unique([userId, platform, platformId])
}

model Post {
  id          String      @id @default(uuid())
  userId      String
  workspaceId String?
  content     String      @db.Text
  mediaUrls   Json        @default("[]")
  status      PostStatus  @default(DRAFT)
  scheduledAt DateTime?
  publishedAt DateTime?
  failReason  String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace? @relation(fields: [workspaceId], references: [id])
  accounts  PostAccount[]
  analytics PostAnalytics[]
}

model PostAccount {
  id              String        @id @default(uuid())
  postId          String
  socialAccountId String
  status          PostStatus    @default(DRAFT)
  platformPostId  String?
  failReason      String?
  publishedAt     DateTime?

  post          Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  socialAccount SocialAccount @relation(fields: [socialAccountId], references: [id], onDelete: Cascade)

  @@unique([postId, socialAccountId])
}

model PostAnalytics {
  id        String   @id @default(uuid())
  postId    String
  platform  Platform
  likes     Int      @default(0)
  comments  Int      @default(0)
  shares    Int      @default(0)
  reach     Int      @default(0)
  clicks    Int      @default(0)
  impressions Int    @default(0)
  fetchedAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
}

enum Role {
  USER
  ADMIN
}

enum WsRole {
  OWNER
  ADMIN
  MEMBER
}

enum Plan {
  FREE
  STARTER
  PRO
  AGENCY
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
  INCOMPLETE
}

enum Platform {
  FACEBOOK
  INSTAGRAM
  TWITTER
  LINKEDIN
  TIKTOK
  THREADS
  YOUTUBE
  PINTEREST
}

enum PostStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  FAILED
  CANCELED
}
